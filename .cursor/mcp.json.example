{
  "mcpServers": {
    "firecrawl": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "FIRECRAWL_API_KEY=${env:FIRECRAWL_API_KEY}",
        "mcp/firecrawl"
      ]
    },
    "@magicuidesign/mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@magicuidesign/mcp@latest"
      ]
    },
    "sequential-thinking": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "mcp/sequentialthinking"
      ]
    },
    "brave-search": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "BRAVE_API_KEY=${env:BRAVE_API_KEY}",
        "mcp/brave-search"
      ]
    },
    "tavily": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "TAVILY_API_KEY=${env:TAVILY_API_KEY}",
        "mcp/tavily"
      ]
    },
    "fetch": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "mcp/fetch"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "Notion": {
      "url": "https://mcp.notion.com/mcp"
    },
    "notion-sse": {
      "type": "sse",
      "url": "https://mcp.notion.com/sse"
    },
    "notion-stdio": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.notion.com/mcp"]
    },
    "notion-open-source": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-notion"
      ],
      "env": {
        "NOTION_API_KEY": "${env:NOTION_API_KEY}",
        "NOTION_API_VERSION": "${env:NOTION_API_VERSION}"
      }
    },
    "openclaw-aab": {
      "command": "openclaw",
      "args": [
        "mcp",
        "serve",
        "--url",
        "wss://aab-openclaw.moodmnky.com",
        "--token-file",
        "${env:OPENCLAW_GATEWAY_TOKEN_FILE}"
      ],
      "description": "OpenClaw remote Gateway over MCP (stdio bridge). Pin `command` to an openclaw 2026.4.15+ binary if your ~/.openclaw config was written by a newer CLI (avoids version-mismatch warnings). Requires gateway token file path in env."
    },
    "poke-mnky-n8n": {
      "command": "npx",
      "args": ["-y", "n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "N8N_API_URL": "${env:N8N_API_URL}",
        "N8N_API_KEY": "${env:N8N_API_KEY}"
      },
      "description": "n8n API for MCP workflows (list/get/update). Set N8N_API_URL (e.g. https://aab-n8n.moodmnky.com) and N8N_API_KEY from n8n Settings → API. Webhook URL for the app is separate: N8N_WEBHOOK_URL in Vercel."
    }
  }
}
